---
const { title, subtitle } = Astro.props;
---

<div class="flex timeline-item">
  <div class="education__time">
    <span class="w-4 h-4 block rounded-full mt-1" style="background-color: rgb(27, 86, 253);"></span>
    <span class="education__line block h-full w-[2px] translate-x-[7px]" style="background-color: rgba(27, 86, 253, 0.3);"></span>
  </div>
  <div class="experience__data bd-grid px-5 pb-10">
    <h3 class="font-bold mb-1 uppercase tracking-wider" style="color: rgb(27, 86, 253); font-family: monospace;">{title}</h3>
    <span class="font-mono text-sm block mb-2" style="color: rgba(27, 86, 253, 0.7);">{subtitle}</span>
    <div class="my-2 text-justify text-sm leading-relaxed" style="color: rgb(27, 86, 253);">
      <slot />
    </div>
  </div>
</div>

<style>
  .timeline-item:last-child .education__line {
    display: none; /* Remove a linha do último item para não sobrar ponta */
  }
</style>