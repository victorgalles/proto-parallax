---
// src/components/GalleryStill.astro
const { foto, index } = Astro.props;
---

<div class="editorial-item no-filter cursor-zoom-in">
  <img 
    src={foto.src} 
    alt={foto.caption || `Still ${index + 1}`} 
    class="editorial-image no-filter"
    loading="lazy"
    onclick={`document.getElementById('modal-gal-${index}').showModal()`}
  /> 
  
  <dialog id={`modal-gal-${index}`} class="lightbox-modal gallery-dialog">
    <div class="modal-content">
      <button class="nav-btn prev" onclick="event.stopPropagation(); changeModal(this, -1)"> &lt; </button>
      
      <div class="image-wrapper" onclick="event.stopPropagation()">
        <img src={foto.src} alt={foto.caption} class="full-image" />
      </div>

      <button class="nav-btn next" onclick="event.stopPropagation(); changeModal(this, 1)"> &gt; </button>
      
      <!-- O NOVO BLOCO ENTRA AQUI, NO LUGAR DO ANTIGO P -->
      <div class="modal-info-container" onclick="event.stopPropagation()">
        <div class="description-block">
          {foto.caption ? foto.caption.split('\n').map((line, i) => {
            const trimmedLine = line.trim();
            if (!trimmedLine) return null;

            // Diferencia Ano, Título (primeira linha após o ano) e Tags
            if (trimmedLine.startsWith('[')) {
              return <span class="desc-year">{trimmedLine}</span>;
            }
            if (trimmedLine.startsWith('#')) {
              return <span class="desc-tags">{trimmedLine}</span>;
            }
            // Se for a primeira linha útil, tratamos como título negrito
            return <span class="desc-main-text">{trimmedLine}</span>;
          }) : <span class="desc-main-text">STILL_0{index + 1}</span>}
        </div>
        
        <button class="close-archive-btn" onclick="window.closeModal(this)">
          // CLOSE_ARCHIVE
        </button>
      </div>
    </div>
  </dialog>
</div>

<style>
  .editorial-item {
    box-sizing: border-box;
    max-width: 100%;
    overflow: hidden;
    display: flex;
  }

  .editorial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Estilos específicos deste componente que não estão no global */
  .description-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* Garante que o container de info seja visível e clicável */
  .modal-info-container {
    pointer-events: auto !important;
  }
</style>