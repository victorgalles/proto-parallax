---
/* Header.astro */
---
<header class="fixed top-0 left-0 w-full p-8 z-50 pointer-events-none">
  <div class="hidden md:flex justify-between items-start w-full">
    <a href="/" class="pointer-events-auto group"> 
      <div class="border-[6px] border-[#1b56fd] px-6 py-2 bg-white/50 backdrop-blur-sm inline-grid place-items-center overflow-hidden hover:bg-white/80 transition-all duration-500 min-w-[440px]">
        <h1 
          id="creative-name" 
          class="text-6xl font-bold lowercase tracking-tighter text-[#1b56fd] whitespace-nowrap col-start-1 row-start-1 z-10"
        >
          victor galles
        </h1>
        <!-- Mantenedor de largura para evitar que o layout dance -->
        <h1 class="text-6xl font-bold lowercase tracking-tighter opacity-0 pointer-events-none col-start-1 row-start-1 select-none">
          victor galles
        </h1>
      </div>
    </a>
    
    <nav class="flex flex-col items-end gap-2 pointer-events-auto text-right">
      <a href="/about" class="text-4xl font-bold text-[#1b56fd] hover:opacity-50 leading-none">About</a>
      <a href="/" class="text-4xl font-bold text-[#1b56fd] hover:opacity-50 leading-none">Selected Works</a>
      <a href="/contact" class="text-4xl font-bold text-[#1b56fd] hover:opacity-50 leading-none">Contact</a>
    </nav>
  </div>

  <!-- Mobile -->
  <div class="flex md:hidden flex-col items-start w-full gap-4 pointer-events-auto">
    <a href="/"> 
      <div class="border-[3px] border-[#1b56fd] px-3 py-1 bg-white/80 backdrop-blur-sm">
        <h1 id="creative-name-mobile" class="text-2xl font-bold lowercase tracking-tighter text-[#1b56fd]">
          victor galles
        </h1>
      </div>
    </a>
    <nav class="flex gap-4 bg-white/80 backdrop-blur-sm px-2 py-1 border-b border-[#1b56fd]">
      <a href="/about" class="text-xs font-bold text-[#1b56fd] uppercase tracking-widest">About</a>
      <a href="/" class="text-xs font-bold text-[#1b56fd] uppercase tracking-widest">Works</a>
      <a href="/contact" class="text-xs font-bold text-[#1b56fd] uppercase tracking-widest">Contact</a>
    </nav>
  </div>
</header>

<script is:inline>
  function initHeaderLogic() {
    const target = document.querySelector("#creative-name");
    const targetMobile = document.querySelector("#creative-name-mobile");
    if (!target) return;

    const names = ["victor galles", "datajunkz"];
    const chars = "01_$#X*+=/-";
    let currentIndex = 0;
    let isHovered = false;
    let isTransitioning = false;

    // Função para embaralhar o texto com base no progresso da revelação
    const getScrambledText = (finalText, iteration) => {
      return finalText.split('').map((char, index) => {
        if (char === " ") return " ";
        if (index < iteration) return char;
        return chars[Math.floor(Math.random() * chars.length)];
      }).join('');
    };

    // 1. LÓGICA DE TRANSIÇÃO ASCII (A cada 10s)
    setInterval(() => {
      if (isHovered || isTransitioning) return;

      isTransitioning = true;
      currentIndex = (currentIndex + 1) % names.length;
      const nextName = names[currentIndex];
      let iteration = 0;

      const interval = setInterval(() => {
        const text = getScrambledText(nextName, iteration);
        target.innerText = text;
        if (targetMobile) targetMobile.innerText = text;

        if (iteration >= nextName.length) {
          clearInterval(interval);
          isTransitioning = false;
        }
        iteration += 1 / 3; // Controla a velocidade da "revelação"
      }, 40);
    }, 10000);

    // 2. LÓGICA DE GLITCH NO HOVER (Frenético)
    let glitchInterval;
    const linkParent = target.closest('a');

    linkParent.addEventListener("mouseenter", () => {
      if (isTransitioning) return;
      isHovered = true;
      glitchInterval = setInterval(() => {
        const currentName = names[currentIndex];
        target.innerText = currentName.split('').map(c => 
          c === " " ? " " : chars[Math.floor(Math.random() * chars.length)]
        ).join('');
      }, 70);
    });

    linkParent.addEventListener("mouseleave", () => {
      isHovered = false;
      clearInterval(glitchInterval);
      if (!isTransitioning) {
        target.innerText = names[currentIndex];
        if (targetMobile) targetMobile.innerText = names[currentIndex];
      }
    });
  }

  // Inicializa e suporta ViewTransitions
  initHeaderLogic();
  document.addEventListener('astro:after-swap', initHeaderLogic);
</script>

<style>
  .inline-grid {
    display: inline-grid;
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    min-height: 100px;
    min-width: 450px; /* Adicione isso para segurar o espaço do nome maior */
  }
  #creative-name {
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.05em;
    /* Garante que o texto use uma fonte mono ou que o espaçamento seja fixo */
    display: inline-block;
  }
</style>