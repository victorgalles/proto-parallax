---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from 'astro:content';

const allProjects = await getCollection('projects');
const galeriaEntry = await getEntry('galeria', 'fotos');
const galeriaFotos = galeriaEntry?.data.fotos || [];
const galeriaDesc = galeriaEntry?.data.description || "";

const pageTitle = "VIC // SELECTED_WORKS";
const getYoutubeThumb = (id) => `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
---

<BaseLayout title={pageTitle}>
  
  <div class="video-gallery">
    {/* Bloco de Projetos (Vídeos/Fotos Principais) - Mantido Intocado */}
    {allProjects.map((project) => (
      <div class="project-row">
        <div class="video-column">
          {project.data.youtubeID ? (
            <div 
              class="video-placeholder" 
              data-video-id={project.data.youtubeID}
              style={`background-image: url(${getYoutubeThumb(project.data.youtubeID)});`}
              onclick="this.innerHTML = `<iframe src='https://www.youtube.com/embed/${this.dataset.videoId}?autoplay=1&modestbranding=1&rel=0' allow='autoplay; encrypted-media' allowfullscreen></iframe>`; this.classList.add('is-playing');"
            >
              <div class="blue-overlay"><span class="play-hint">PLAY_VIDEO</span></div>
            </div>
          ) : (
            <div class="image-container no-filter cursor-zoom-in">
              {project.data.image && (
                <img src={project.data.image} alt={project.data.title} class="project-image-tag no-filter" onclick={`document.getElementById('modal-${project.id}').showModal()`} />
                <dialog id={`modal-${project.id}`} class="lightbox-modal" onclick="this.close()">
                  <div class="modal-content">
                    <img src={project.data.image} alt={project.data.title} class="full-image" />
                    <p class="modal-caption">{project.data.title} // CLOSE</p>
                  </div>
                </dialog>
              )}
            </div>
          )}
        </div>
        <div class="info-column">
          <div class="info-content">
            <div class="meta-header">
              {project.data.date && <span class="project-date">[{project.data.date}]</span>}
              <h2 class="project-title">{project.data.title}</h2>
            </div>
            <p class="project-description">{project.data.description || "Experimental digital art piece."}</p>
            <div class="project-tags">
              {project.data.tags?.map(tag => <span class="tag">#{tag.toLowerCase()}</span>)}
            </div>
          </div>
        </div>
      </div>
    ))}

    {/* SEÇÃO DE GALERIA EDITORIAL (Layout Irregular) */}
    {galeriaFotos.length > 0 && (
      <div class="editorial-gallery-container">
        <div class="gallery-info">
          <span class="project-date">[GALLERY_STILLS]</span>
          {galeriaDesc && <p class="gallery-description">{galeriaDesc}</p>}
        </div>

        <div class="editorial-grid">
          {galeriaFotos.map((foto, index) => (
            <div class="editorial-item no-filter cursor-zoom-in">
              <img 
                src={foto} 
                alt={`Still ${index + 1}`} 
                class="editorial-image no-filter"
                onclick={`document.getElementById('modal-gal-${index}').showModal()`}
              />
              <dialog id={`modal-gal-${index}`} class="lightbox-modal" onclick="this.close()">
                <div class="modal-content">
                  <img src={foto} alt={`Still ${index + 1}`} class="full-image" />
                  <p class="modal-caption">{`[STILL_0${index + 1}]`} // CLOSE</p>
                </div>
              </dialog>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* Base Layout & Projetos - Estritamente Mantidos */
  .video-gallery { max-width: 1100px; margin: 40px auto 100px auto; padding: 0 40px; display: flex; flex-direction: column; gap: 80px; }
  .project-row { display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 50px; }
  .project-row:nth-child(even) { direction: rtl; }
  .project-row:nth-child(even) .info-content { direction: ltr; }
  .video-placeholder, .image-container { width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(27, 86, 253, 0.4); overflow: hidden; position: relative; background-size: cover; background-position: center; }
  .project-image-tag { width: 100%; height: 100%; object-fit: cover; }
  .blue-overlay { position: absolute; inset: 0; background-color: rgba(27, 86, 253, 0.6); opacity: 0; display: flex; align-items: center; justify-content: center; transition: opacity 0.3s ease; }
  .play-hint { color: white; font-family: monospace; font-size: 0.7rem; border: 1px solid white; padding: 4px 8px; }
  .video-placeholder:hover .blue-overlay { opacity: 1; }
  .lightbox-modal { border: none; background: transparent; outline: none; }
  .lightbox-modal::backdrop { background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); }
  .modal-content { display: flex; flex-direction: column; align-items: center; cursor: zoom-out; }
  .full-image { max-width: 90vw; max-height: 80vh; border: 1px solid rgb(27, 86, 253); }
  .modal-caption { margin-top: 10px; font-family: monospace; font-size: 0.7rem; color: rgb(27, 86, 253); text-transform: uppercase; }
  .project-date { font-family: monospace; font-size: 0.7rem; color: rgb(27, 86, 253); opacity: 0.5; display: block; }
  .project-title { font-size: 0.9rem; font-weight: 900; text-transform: uppercase; color: rgb(27, 86, 253); }
  .project-description { font-size: 0.85rem; line-height: 1.4; color: rgb(27, 86, 253); margin-bottom: 15px; max-width: 380px; }
  .tag { font-size: 0.65rem; color: rgb(27, 86, 253); font-family: monospace; opacity: 0.6; margin-right: 8px; }

  /* NOVA GALERIA EDITORIAL - DESIGN IRREGULAR E RESPIRÁVEL */
  .editorial-gallery-container { margin-top: 100px; }
  .gallery-description { font-size: 0.85rem; font-style: italic; color: rgb(27, 86, 253); opacity: 0.8; margin-bottom: 40px; }

  .editorial-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4 colunas base */
    gap: 30px; /* Mais espaço entre as fotos para "respirar" */
    grid-auto-flow: dense;
  }

  .editorial-item {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(27, 86, 253, 0.1);
    background: #f9f9f9;
    transition: transform 0.4s ease;
  }

  /* Lógica "Aleatória" controlada */
  /* Fotos 1, 5, 9... são grandes e horizontais */
  .editorial-item:nth-child(4n+1) { grid-column: span 2; grid-row: span 2; aspect-ratio: 1/1; }
  
  /* Fotos 2, 6, 10... são verticais */
  .editorial-item:nth-child(4n+2) { grid-column: span 1; grid-row: span 2; aspect-ratio: 9/16; }

  /* Fotos 3, 7... são pequenas 16:9 */
  .editorial-item:nth-child(4n+3) { grid-column: span 2; grid-row: span 1; aspect-ratio: 16/9; }

  /* Fotos 4, 8... são quadradas pequenas */
  .editorial-item:nth-child(4n+4) { grid-column: span 1; grid-row: span 1; aspect-ratio: 1/1; }

  .editorial-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .editorial-item:hover .editorial-image { transform: scale(1.05); }
  .editorial-item:hover { border-color: rgba(27, 86, 253, 0.4); }

  .no-filter { filter: none !important; }

  @media (max-width: 900px) {
    .editorial-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    .editorial-item:nth-child(n) { grid-column: span 1; grid-row: span 1; aspect-ratio: 16/9; }
    .project-row { grid-template-columns: 1fr; }
  }

  
</style>