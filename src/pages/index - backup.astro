---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const pageTitle = "VIC // SELECTED_WORKS";

const getYoutubeThumb = (id) => `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
---

<BaseLayout title={pageTitle}>
  
  <div class="video-gallery">
    {allProjects.length === 0 && <p class="error-msg">Nenhum projeto encontrado.</p>}
    
    {allProjects.map((project) => (
      <div class="project-row">
        <div class="video-column">
          <div 
            class="video-placeholder" 
            data-video-id={project.data.youtubeID}
            style={`background-image: url(${getYoutubeThumb(project.data.youtubeID)});`}
            onclick="this.innerHTML = `<iframe src='https://www.youtube.com/embed/${this.dataset.videoId}?autoplay=1&modestbranding=1&rel=0' allow='autoplay; encrypted-media' allowfullscreen></iframe>`; this.classList.add('is-playing');"
          >
            <div class="blue-overlay"></div>
          </div>
        </div>

        <div class="info-column">
          <div class="info-content">
            <h2 class="project-title">{project.data.title}</h2>
            <p class="project-description">
              {project.data.description || "Experimental digital art piece exploring technology and movement."}
            </p>
            <div class="project-tags">
              {project.data.tags?.map(tag => (
                <span class="tag">#{tag.toUpperCase()}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}

    <div class="photo-break-grid">
      <div class="photo-item large" style="background-image: url('/fotos/ensaio-01.jpg');">
        <span class="photo-label">[STILL_01]</span>
      </div>
      <div class="photo-column-stack">
        <div class="photo-item small" style="background-image: url('/fotos/ensaio-02.jpg');">
           <span class="photo-label">[STILL_02]</span>
        </div>
        <div class="photo-item small" style="background-image: url('/fotos/ensaio-03.jpg');">
           <span class="photo-label">[STILL_03]</span>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>

<style>
  /* Layout Geral */
  .video-gallery {
    max-width: 1200px;
    margin: 60px auto 100px auto; 
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    gap: 120px;
  }

  /* Estilos Projetos de Vídeo */
  .project-row {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 80px;
  }

  .project-row:nth-child(even) { direction: rtl; }
  .project-row:nth-child(even) .info-content { direction: ltr; }

  .video-placeholder {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background-size: cover;
    background-position: center;
    border: 1px solid rgb(27, 86, 253);
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.4s ease;
  }

  .video-placeholder:hover { transform: scale(1.02); }

  .blue-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-color: rgba(27, 86, 253, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 20;
  }

  .video-placeholder:hover .blue-overlay { opacity: 1; }

  .project-title {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 0.9;
    margin-bottom: 20px;
    text-transform: uppercase;
    color: rgb(27, 86, 253);
    letter-spacing: -2px;
  }

  .project-description {
    font-size: 1.1rem;
    line-height: 1.4;
    color: rgb(27, 86, 253);
    margin-bottom: 30px;
  }

  .tag {
    font-size: 0.75rem;
    color: rgb(27, 86, 253);
    border: 1px solid rgba(27, 86, 253, 0.2);
    padding: 3px 8px;
    font-family: monospace;
  }

  /* ESTILOS DA GALERIA DE FOTOS */
  .photo-break-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 20px;
    height: 500px;
    margin: 60px 0;
  }

  .photo-column-stack {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 20px;
  }

  .photo-item {
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(27, 86, 253, 0.3);
    position: relative;
    filter: grayscale(100%) brightness(0.9);
    transition: all 0.5s ease;
  }

  .photo-item:hover {
    filter: grayscale(0%) brightness(1);
    border-color: rgb(27, 86, 253);
  }

  .photo-label {
    position: absolute;
    bottom: 10px;
    left: 10px;
    font-family: monospace;
    font-size: 0.7rem;
    color: rgb(27, 86, 253);
    background: white;
    padding: 2px 5px;
  }

  @media (max-width: 900px) {
    .project-row, .photo-break-grid { 
      grid-template-columns: 1fr;
      direction: ltr;
      height: auto;
    }
    .photo-item { aspect-ratio: 4/3; }
  }
</style>