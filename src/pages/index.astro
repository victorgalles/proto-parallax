---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, getEntry } from 'astro:content';

const allProjects = await getCollection('projects');
const galeriaEntry = await getEntry('galeria', 'fotos');
const galeriaFotos = galeriaEntry?.data.fotos || [];
const galeriaDesc = galeriaEntry?.data.description || "";

const pageTitle = "victor galles // datajunkz";

const getYoutubeThumb = (id) => `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
---

<BaseLayout title={pageTitle}>
  <div class="video-gallery">
    {allProjects.map((project) => (
      <div class="project-row">
        <div class="video-column">
          {project.data.youtubeID ? (
            <div 
              class="video-placeholder" 
              data-video-id={project.data.youtubeID}
              style={`background-image: url(${getYoutubeThumb(project.data.youtubeID)});`}
              onclick="if(window.innerWidth > 900) { this.innerHTML = `<iframe src='https://www.youtube.com/embed/${this.dataset.videoId}?autoplay=1&modestbranding=1&rel=0' allow='autoplay; encrypted-media' allowfullscreen></iframe>`; this.classList.add('is-playing'); }"
            >
              <a href={`https://www.youtube.com/watch?v=${project.data.youtubeID}`} target="_blank" class="mobile-only-link"></a>
              <div class="blue-overlay"><span class="play-hint">PLAY_VIDEO</span></div>
            </div>
          ) : project.data.videoLocal ? (
            <div class="video-placeholder local-video-container">
              <video src={project.data.videoLocal} autoplay loop muted playsinline class="project-video-tag no-filter"></video>
            </div>
          ) : (
            <div class="image-container no-filter cursor-zoom-in">
              {project.data.image && (
                <img src={project.data.image} alt={project.data.title} class="project-image-tag no-filter" loading="lazy" onclick={`document.getElementById('modal-${project.id}').showModal()`} />
              )}
            </div>
          )}
        </div>
        
        <div class="info-column">
          <div class="info-content">
            <div class="meta-header">
              {project.data.date && <span class="project-date">[{project.data.date}]</span>}
              <h2 class="project-title">{project.data.title}</h2>
            </div>
            <p class="project-description">{project.data.description || "Experimental digital art piece."}</p>
            <div class="project-tags">
              {project.data.tags?.map(tag => <span class="tag">#{tag.toLowerCase()}</span>)}
            </div>
          </div>
        </div>
      </div>
    ))}

    {galeriaFotos.length > 0 && (
      <div class="editorial-gallery-container">
        <div class="gallery-info">
          <span class="project-date">[GALLERY_STILLS]</span>
          {galeriaDesc && <p class="gallery-description">{galeriaDesc}</p>} <br>
        </div>

        <div class="editorial-grid">
          {galeriaFotos.map((foto, index) => (
            <div class="editorial-item no-filter cursor-zoom-in">
              <img 
                src={foto.src} 
                alt={foto.caption || `Still ${index + 1}`} 
                class="editorial-image no-filter"
                loading="lazy"
                onclick={`document.getElementById('modal-gal-${index}').showModal()`}
              />
              
              <dialog id={`modal-gal-${index}`} class="lightbox-modal gallery-dialog" onclick="if(event.target==this) this.close()">
                <div class="modal-content">
                  <button class="nav-btn prev" onclick="event.stopPropagation(); window.changeModal(this, -1)">&#8249;</button>
                  <button class="nav-btn next" onclick="event.stopPropagation(); window.changeModal(this, 1)">&#8250;</button>

                  <div class="image-wrapper">
                    <img src={foto.src} alt={foto.caption} class="full-image" />
                  </div>

                  <div class="modal-info-container" onclick="event.stopPropagation();">
                    <div class="description-block">
                        <span class="desc-year">[STILL_ARCHIVE]</span>
                        <span class="desc-main-text">{foto.caption || "UNTITLED_STILL"}</span>
                    </div>
                    <button class="close-archive-btn" onclick="this.closest('dialog').close()">// CLOSE</button>
                  </div>
                </div>
              </dialog>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<script is:inline>
  window.changeModal = function(btn, dir) {
    const current = btn.closest('dialog');
    const idParts = current.id.split('-');
    const idNum = parseInt(idParts[idParts.length - 1]);
    const allDialogs = document.querySelectorAll('.gallery-dialog');
    const nextNum = (idNum + dir + allDialogs.length) % allDialogs.length;
    current.close();
    document.getElementById(`modal-gal-${nextNum}`).showModal();
  };
</script>

<style>
  /* --- BASE PC --- */
  .video-gallery { max-width: 1100px; margin: 100px auto; padding: 0 40px; display: flex; flex-direction: column; gap: 80px; }
  .project-row { display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 50px; }
  .project-row:nth-child(even) { direction: rtl; }
  .project-row:nth-child(even) .info-content { direction: ltr; }
  
  .video-placeholder, .image-container { 
    width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(27, 86, 253, 0.4); 
    overflow: hidden; position: relative; background-size: cover; background-position: center; 
  }
  .project-video-tag { width: 100%; height: 100%; object-fit: cover; }
  .blue-overlay { position: absolute; inset: 0; background: rgba(27, 86, 253, 0.6); opacity: 0; display: flex; align-items: center; justify-content: center; transition: 0.3s; }
  .video-placeholder:hover .blue-overlay { opacity: 1; }
  .play-hint { color: white; font-family: monospace; border: 1px solid white; padding: 4px 8px; font-size: 0.7rem; }

  /* --- TEXTOS --- */
  .project-date { font-family: monospace; font-size: 0.7rem; color: #1b56fd; opacity: 0.5; }
  .project-title { font-size: 0.9rem; font-weight: 900; text-transform: uppercase; color: #1b56fd; }
  .project-description { font-size: 0.85rem; line-height: 1.4; color: #1b56fd; max-width: 380px; }
  .tag { font-size: 0.65rem; color: #1b56fd; font-family: monospace; opacity: 0.6; margin-right: 8px; }

  /* --- EDITORIAL GRID (ESTRUTURA FIXA) --- */
  .editorial-gallery-container { margin-top: 100px; border-top: 1px solid rgba(27, 86, 253, 0.3); padding-top: 40px; width: 100%; }
  .editorial-grid { 
    display: grid; grid-template-columns: repeat(4, 1fr); grid-auto-rows: 200px; 
    gap: 0px; grid-auto-flow: dense; border: 0.5px solid rgba(27, 86, 253, 0.2); 
  }
  .editorial-item { 
    position: relative; overflow: hidden; border: 0.5px solid rgba(27, 86, 253, 0.2); 
    grid-column: span 2; display: flex; 
  }
  .editorial-item:nth-child(3n) { grid-column: span 1; grid-row: span 2; }
  .editorial-item:nth-child(5n) { grid-column: span 1; grid-row: span 1; }
  .editorial-image { width: 100%; height: 100%; object-fit: cover; transition: 0.6s; }
  .editorial-item:hover .editorial-image { transform: scale(1.05); }

  /* --- MODAL / LIGHTBOX --- */
  .lightbox-modal { border: none; background: transparent; width: 100vw; height: 100vh; max-width: 100vw; margin: 0; padding: 0; overflow: hidden; }
  .lightbox-modal::backdrop { background: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px); }
  .modal-content { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; position: relative; }
  .image-wrapper { max-width: 85vw; height: 70vh; display: flex; align-items: center; }
  .full-image { max-width: 100%; max-height: 100%; border: 1px solid #1b56fd; object-fit: contain; }
  
  .nav-btn { position: absolute; top: 50%; background: none; border: none; color: #1b56fd; font-size: 3rem; cursor: pointer; padding: 20px; z-index: 10; }
  .prev { left: 10px; } .next { right: 10px; }
  
  .modal-info-container { width: 85vw; margin-top: 20px; display: flex; justify-content: space-between; border-top: 1px solid rgba(27,86,253,0.3); padding-top: 15px; color: #1b56fd; font-family: monospace; }
  .desc-main-text { font-weight: 900; text-transform: uppercase; }
  .close-archive-btn { background: transparent; border: 1px solid #1b56fd; color: #1b56fd; padding: 4px 10px; cursor: pointer; font-family: monospace; font-size: 0.7rem; }

 /* --- MOBILE AJUSTES (MARGENS ESTREITAS) --- */
  @media (max-width: 900px) {
    .video-gallery { 
      padding: 1px 0px; /* Mantém o espaçamento vertical */
      gap: 50px; 
    }

    .project-row { 
      display: flex; 
      flex-direction: column; 
      gap: 15px; 
      direction: ltr !important; 
    }

    /* O vídeo/imagem ocupa 100% da largura da tela */
    .video-column, .image-container { 
      width: 100%; 
    }

    .video-placeholder, .image-container { 
      border-left: none; 
      border-right: none; 
    }

    /* AJUSTE AQUI: Controla a margem do texto */
    .info-content { 
      padding: 0 15px; /* Diminuído de 25px para 15px para ficar mais estreito */
    }

    .project-title { font-size: 0.85rem; }
    .project-description { max-width: 100%; font-size: 0.8rem; }

    /* Grade Editorial Mobile */
    .editorial-gallery-container {
      padding: 30px 10px; /* Margem pequena nas laterais da grade */
    }
    
    .editorial-grid { 
      grid-template-columns: repeat(2, 1fr); 
      grid-auto-rows: 120px; 
    }
    
    .editorial-item { grid-column: span 1; }
    .editorial-item:nth-child(3n) { grid-column: span 2; }
    
    /* Modal Mobile */
    .modal-info-container { width: 92vw; }
    .desc-main-text { font-size: 0.75rem; }
  }

  .no-filter { filter: none !important; }
</style>