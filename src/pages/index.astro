---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import GalleryStill from "../components/GalleryStill.astro";
import { getCollection, getEntry } from 'astro:content';

const allProjects = await getCollection('projects');
const galeriaEntry = await getEntry('galeria', 'fotos');
const galeriaFotos = galeriaEntry?.data.fotos || [];
const galeriaDesc = galeriaEntry?.data.description || "";

const pageTitle = "victor galles // datajunkz";
---

<BaseLayout title={pageTitle}>
  <div class="video-gallery">
    
    {allProjects.map((project) => (
      <ProjectCard project={project} />
    ))}

    <div class="section-divider">
      <h2 class="section-label">[VISUAL_ARCHIVE // STILLS]</h2>
      {galeriaDesc && <p class="gallery-description">{galeriaDesc}</p>}
    </div>

    <div class="editorial-grid">
      {galeriaFotos.map((foto, index) => (
        <GalleryStill foto={foto} index={index} />
      ))}
    </div>

  </div>
</BaseLayout>

<script is:inline>
  // Tornamos as funções globais anexando-as ao objeto window
  // Isso garante que o 'onclick' dentro dos componentes funcione
  window.changeModal = function(element, direction) {
    const currentDialog = element.closest('dialog');
    const currentIndex = parseInt(currentDialog.id.replace('modal-gal-', ''));
    const dialogs = document.querySelectorAll('.gallery-dialog');
    const total = dialogs.length;
    
    let nextIndex = currentIndex + direction;
    if (nextIndex >= total) nextIndex = 0;
    if (nextIndex < 0) nextIndex = total - 1;

    currentDialog.close();
    document.getElementById(`modal-gal-${nextIndex}`).showModal();
  }

  window.setupDialogs = function() {
    const dialogs = document.querySelectorAll('dialog');
    
    dialogs.forEach(dialog => {
      // Clique fora para fechar
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) {
          dialog.close();
        }
      });
    });

    // Atalhos de teclado
    document.addEventListener('keydown', (e) => {
      const openDialog = document.querySelector('dialog[open].gallery-dialog');
      if (!openDialog) return;

      if (e.key === 'ArrowRight') {
        const btn = openDialog.querySelector('.next');
        if (btn) window.changeModal(btn, 1);
      }
      if (e.key === 'ArrowLeft') {
        const btn = openDialog.querySelector('.prev');
        if (btn) window.changeModal(btn, -1);
      }
    });
  }

  // Execução inicial
  window.setupDialogs();
  
  // Compatibilidade com ViewTransitions
  document.addEventListener('astro:after-swap', window.setupDialogs);
</script>

<style is:global>
  
  .video-gallery { max-width: 1100px; margin: 120px auto 100px auto; padding: 0 40px; display: flex; flex-direction: column; gap: 80px; }
  
  .project-row { display: grid; grid-template-columns: 1.2fr 0.8fr; align-items: center; gap: 50px; }
  .project-row:nth-child(even) { direction: rtl; }
  .project-row:nth-child(even) .info-content { direction: ltr; }
  
  .video-placeholder, .image-container { width: 100%; aspect-ratio: 16/9; border: 1px solid rgba(27, 86, 253, 0.4); overflow: hidden; position: relative; background-size: cover; background-position: center; background-color: #f0f0f0; }
  
  .editorial-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0px; grid-auto-flow: dense; align-items: stretch; }
  .editorial-item { position: relative; overflow: hidden; border: 1px solid rgba(27, 86, 253, 0.1); background: #f0f0f0; transition: transform 0.4s ease; grid-column: span 2; aspect-ratio: 16/9; }
  .editorial-item:nth-child(3n) { grid-column: span 1; grid-row: span 2; aspect-ratio: 3/4; }
  .editorial-item:nth-child(5n) { grid-column: span 1; grid-row: span 1; aspect-ratio: 1/1; }

  .project-video-tag, .project-image-tag, .editorial-image { width: 100%; height: 100%; object-fit: cover; display: block; }
  .editorial-image { transition: transform 0.6s ease; }
  .editorial-item:hover .editorial-image { transform: scale(1.05); }

  .blue-overlay { position: absolute; inset: 0; background-color: rgba(27, 86, 253, 0.6); opacity: 0; display: flex; align-items: center; justify-content: center; transition: opacity 0.3s ease; z-index: 2; }
  .play-hint { color: white; font-family: monospace; font-size: 0.7rem; border: 1px solid white; padding: 4px 8px; }
  .video-placeholder:hover .blue-overlay { opacity: 1; }

  /* Iframe fix */
  .video-placeholder iframe { width: 100%; height: 100%; border: none; }

  /* MODAL */

  .lightbox-modal { border: none; background: transparent; outline: none; width: 100vw; height: 100vh; max-width: 100vw; max-height: 100vh; margin: 0; padding: 0; overflow: hidden; }
  .lightbox-modal::backdrop { background: rgba(0, 0, 0, 0.9); backdrop-filter: blur(10px); }
  
  .modal-content { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; height: 100%; position: relative; pointer-events: none; }
  .image-wrapper, .nav-btn, .modal-caption { pointer-events: auto; }

  .image-wrapper { display: flex; justify-content: center; align-items: center; max-width: 80vw; height: 80vh; }
  .full-image { max-width: 100%; max-height: 100%; border: 1px solid rgba(27, 86, 253, 0.5); object-fit: contain; }

  .nav-btn { background: none; border: none; color: #1b56fd; font-family: monospace; font-size: 3rem; cursor: pointer; padding: 40px; transition: opacity 0.2s, color 0.2s; z-index: 10; position: absolute; top: 50%; transform: translateY(-50%); }
  .nav-btn.prev { left: 20px; }
  .nav-btn.next { right: 20px; }
  .nav-btn:hover { color: white; }

  .modal-caption { margin-top: 15px; font-family: monospace; font-size: 0.7rem; color: #1b56fd; text-transform: uppercase; letter-spacing: 1px; border: 1px solid rgba(27, 86, 253, 0.3); padding: 4px 10px; background: rgba(27, 86, 253, 0.05); }

  .section-divider { border-top: 1px solid rgba(27, 86, 253, 0.3); margin: 100px 0 40px 0; padding-top: 20px; text-align: left; }
  .section-label { font-family: monospace; color: rgb(27, 86, 253); font-weight: 900; text-transform: uppercase; letter-spacing: 2px; }

  @media (max-width: 900px) {
    .video-gallery { margin-top: 0 !important; padding: 100px 20px 50px 20px; gap: 60px; }
    .project-row { grid-template-columns: 1fr !important; gap: 20px; }
    .editorial-grid { grid-template-columns: repeat(2, 1fr); gap: 0px; }
    .nav-btn { font-size: 2rem; padding: 15px; }
    .nav-btn.prev { left: 5px; }
    .nav-btn.next { right: 5px; }
    .image-wrapper { max-width: 95vw; }
  }

  .no-filter { filter: none !important; }
  .cursor-zoom-in { cursor: zoom-in; }
</style>